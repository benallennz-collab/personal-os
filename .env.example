VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (used by api/voice-command.js) — never prefix this with VITE_,
# or Vite will bundle it into client-side JS anyone can read.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Server-side only (used by api/text-to-speech.js) — powers the New Zealand voice.
# Optional: without these, the voice assistant falls back to the browser's built-in voice.
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-region
